/**
 * Data class untuk mewakili mesej dalam chat.
 */
data class ChatMessage(
    val text: String,
    val isUser: Boolean,
    val timestamp: Long = System.currentTimeMillis()
)

/**
 * ChatViewModel - Mengendalikan logik perniagaan untuk AI 'CyberZoner'.
 * Menggunakan Gemini 1.5 Flash untuk analisis multimodal (teks & imej).
 */
class ChatViewModel : ViewModel() {

    private val _messages = MutableStateFlow<List<ChatMessage>>(emptyList())
    val messages = _messages.asStateFlow()

    private val _isLoading = MutableStateFlow(false)
    val isLoading = _isLoading.asStateFlow()

    // 1. KONFIGURASI MODEL & SISTEM INSTRUKSI
    // Menggunakan 'systemInstruction' untuk menetapkan persona CyberZoner secara kekal.
    private val model = Firebase.ai.generativeModel(
        modelName = "gemini-1.5-flash",
        systemInstruction = content { 
            text(
                "Kau adalah 'CyberZoner', sebuah AI pembantu pakar keselamatan siber dan penggodam beretika. " +
                "Gaya bahasa kau adalah teknikal, ringkas, dan menggunakan terminologi terminal. " +
                "Jika user menghantar imej kod atau log sistem, kau mesti menganalisis kelemahan (vulnerabilities). " +
                "Jangan menjawab soalan yang tidak berkaitan dengan teknologi, kod, atau sekuriti."
            )
        }
    )

    /**
     * Menukar Uri kepada Bitmap dengan pengendalian memori yang efisien.
     * Dijalankan dalam Dispatchers.IO untuk mengelakkan UI jank.
     */
    suspend fun uriToBitmap(context: Context, uri: Uri): Bitmap? = withContext(Dispatchers.IO) {
        return@withContext try {
            if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.P) {
                val source = ImageDecoder.createSource(context.contentResolver, uri)
                ImageDecoder.decodeBitmap(source) { decoder, _, _ ->
                    decoder.allocator = ImageDecoder.ALLOCATOR_SOFTWARE
                    decoder.isMutableRequired = true
                }
            } else {
                @Suppress("DEPRECATION")
                MediaStore.Images.Media.getBitmap(context.contentResolver, uri)
            }
        } catch (e: Exception) {
            null
        }
    }

    /**
     * Menghantar input pengguna ke API Gemini.
     * @param prompt Teks dari input pengguna.
     * @param image Bitmap pilihan jika pengguna melampirkan imej.
     */
    fun sendCyberPayload(prompt: String, image: Bitmap? = null) {
        // Validasi input: Jangan hantar jika kedua-duanya kosong
        if (prompt.isBlank() && image == null) return

        val userDisplayText = if (prompt.isBlank() && image != null) {
            "[System: Analisis Imej Dimulakan]"
        } else {
            prompt
        }

        // Tambah mesej pengguna ke dalam senarai secara atomik
        _messages.update { it + ChatMessage(userDisplayText, true) }
        _isLoading.value = true

        viewModelScope.launch {
            try {
                // Sediakan content multimodal
                val inputContent = content {
                    image?.let { image(it) }
                    text(prompt)
                }

                // Pelaksanaan API Call
                val response = model.generateContent(inputContent)
                
                val responseText = response.text ?: "ERR: Kegagalan dekripsi respon dari server."
                
                _messages.update { it + ChatMessage(responseText, false) }

            } catch (e: Exception) {
                // Log ralat teknikal dalam gaya terminal CyberZoner
                val errorMsg = "FATAL ERROR: ${e.localizedMessage ?: "Connection Timeout"}. Sila semak sambungan rangkaian."
                _messages.update { it + ChatMessage(errorMsg, false) }
            } finally {
                _isLoading.value = false
            }
        }
    }
    
    /**
     * Membersihkan sejarah chat jika perlu.
     */
    fun clearTerminal() {
        _messages.value = emptyList()
    }
